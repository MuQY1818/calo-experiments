{
  "experiments": {
    "deployment": "openwhisk",
    "update_code": false,
    "update_storage": false,
    "download_results": false,
    "architecture": "x64",
    "container_deployment": true,
    "runtime": {
      "language": "python",
      "version": "3.11"
    },
    "type": "perf-cost",
    "perf-cost": {
      "benchmark": "110.dynamic-html",
      "experiments": [
        "warm"
      ],
      "input-size": "test",
      "repetitions": 5,
      "concurrent-invocations": 1,
      "memory-sizes": [
        128,
        512,
        1024
      ]
    }
  },
  "deployment": {
    "name": "openwhisk",
    "openwhisk": {
      "shutdownStorage": false,
      "removeCluster": false,
      "wskExec": "wsk",
      "wskBypassSecurity": true,
      "experimentalManifest": false,
      "docker_registry": {
        "registry": "",
        "username": "",
        "password": ""
      },
      "storage": {
        "object": {
          "type": "minio",
          "minio": {
            "mapped_port": 9011,
            "version": "RELEASE.2024-07-16T23-46-41Z",
            "data_volume": "minio-volume"
          }
        },
        "nosql": {
          "type": "scylladb",
          "scylladb": {
            "mapped_port": 9012,
            "version": "2025.2",
            "cpus": 1,
            "memory": 750,
            "data_volume": "scylladb-volume"
          }
        }
      }
    }
  }
}
