{
  "description": "CALO Azure trace-driven simulator configuration",
  "benchmarks": [
    "110.dynamic-html",
    "120.uploader",
    "210.thumbnailer",
    "311.compression",
    "411.image-recognition"
  ],
  "algorithms": [
    "ppo",
    "bayes_opt_online",
    "default",
    "random",
    "greedy"
  ],
  "environment": {
    "episode_length": 60,
    "load_change_freq": 1,
    "calibration_dir": null,
    "action_space": {
      "preset": "calibrated_x64_8"
    },
    "switch_penalty": 0.02,
    "adaptation_penalty": 0.01,
    "normalize_reward": true,
    "reward_weights": {
      "latency": 0.7,
      "cost": 0.3
    },
    "success_bonus": 0.7,
    "cost_normalization": "log",
    "load_patterns": [
      "azure_trace"
    ],
    "workload_source": "azure_trace",
    "azure_profile_path": "external_data/azure_functions/processed/azure_functions_2019_topk_minute_profiles.csv",
    "azure_summary_path": "external_data/azure_functions/processed/azure_functions_2019_function_summary.csv",
    "azure_top_k": 200,
    "azure_profile_selection": "benchmark_aware",
    "azure_selection_pool_size": 12,
    "azure_arrival_scale": 1.0,
    "azure_max_arrivals_per_step": 64
  },
  "training": {
    "total_timesteps": 90000,
    "ppo_kwargs": {
      "learning_rate": 0.00015,
      "n_steps": 2048,
      "batch_size": 256,
      "n_epochs": 12,
      "gamma": 0.995,
      "gae_lambda": 0.97,
      "clip_range": 0.2,
      "ent_coef": 0.005,
      "vf_coef": 0.6,
      "max_grad_norm": 0.5,
      "verbose": 0
    }
  },
  "evaluation": {
    "n_episodes": 5
  },
  "baseline": {
    "reoptimize_freq": 10,
    "default_memory": 512
  },
  "reproducibility": {
    "seeds": [
      42,
      52,
      62
    ]
  }
}
