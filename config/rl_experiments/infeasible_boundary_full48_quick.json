{
  "description": "Quick full-48 probe for infeasible-boundary-aware calibrated simulator",
  "benchmarks": [
    "411.image-recognition"
  ],
  "algorithms": [
    "ppo",
    "bayes_opt_online",
    "greedy",
    "default"
  ],
  "environment": {
    "episode_length": 60,
    "load_change_freq": 5,
    "calibration_dirs": {
      "x64": "results/openwhisk_calibration_x64_stage2_prime",
      "arm64": "results/openwhisk_calibration_arm64_stage1"
    },
    "action_space": {
      "preset": "full_48"
    },
    "switch_penalty": 0.02,
    "adaptation_penalty": 0.01,
    "normalize_reward": true,
    "reward_weights": {
      "latency": 0.7,
      "cost": 0.3
    },
    "success_bonus": 0.7,
    "cost_normalization": "log",
    "load_patterns": [
      "spike"
    ]
  },
  "training": {
    "total_timesteps": 12000,
    "ppo_kwargs": {
      "learning_rate": 0.00015,
      "n_steps": 1024,
      "batch_size": 128,
      "n_epochs": 8,
      "gamma": 0.995,
      "gae_lambda": 0.97,
      "clip_range": 0.2,
      "ent_coef": 0.005,
      "vf_coef": 0.6,
      "max_grad_norm": 0.5,
      "verbose": 0
    }
  },
  "evaluation": {
    "n_episodes": 5
  },
  "baseline": {
    "reoptimize_freq": 10,
    "default_memory": 512
  },
  "reproducibility": {
    "seeds": [
      42
    ]
  }
}
