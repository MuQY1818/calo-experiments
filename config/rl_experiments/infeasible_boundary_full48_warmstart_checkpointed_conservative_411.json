{
  "description": "Conservative full-48 PPO probe with bootstrap-selected oracle-shortlist warm-start and early validation checkpoint selection on 411.image-recognition under spike load",
  "benchmarks": [
    "411.image-recognition"
  ],
  "algorithms": [
    "ppo",
    "bayes_opt_online",
    "greedy",
    "default"
  ],
  "environment": {
    "episode_length": 60,
    "load_change_freq": 5,
    "calibration_dirs": {
      "x64": "results/openwhisk_calibration_x64_stage2_prime",
      "arm64": "results/openwhisk_calibration_arm64_stage1"
    },
    "action_space": {
      "preset": "full_48"
    },
    "switch_penalty": 0.02,
    "adaptation_penalty": 0.01,
    "normalize_reward": true,
    "reward_weights": {
      "latency": 0.7,
      "cost": 0.3
    },
    "success_bonus": 0.7,
    "cost_normalization": "log",
    "load_patterns": [
      "spike"
    ]
  },
  "training": {
    "total_timesteps": 32768,
    "ppo_kwargs": {
      "learning_rate": 0.00008,
      "n_steps": 2048,
      "batch_size": 256,
      "n_epochs": 10,
      "gamma": 0.995,
      "gae_lambda": 0.97,
      "clip_range": 0.15,
      "ent_coef": 0.002,
      "vf_coef": 0.6,
      "max_grad_norm": 0.5,
      "verbose": 0
    },
    "imitation_warmstart": {
      "enabled": true,
      "mode": "oracle_shortlist",
      "bootstrap_top_k": 6,
      "bootstrap_eval_episodes": 2,
      "n_episodes": 10,
      "epochs": 8,
      "batch_size": 256
    },
    "checkpoint_selection": {
      "enabled": true,
      "eval_freq_steps": 4096,
      "n_episodes": 8,
      "metric": "mean_reward",
      "min_timestep": 4096
    }
  },
  "evaluation": {
    "n_episodes": 8
  },
  "baseline": {
    "reoptimize_freq": 10,
    "default_memory": 512
  },
  "reproducibility": {
    "seeds": [
      42
    ]
  }
}
