{
  "description": "Targeted x64-only PPO warm-start probe with validation checkpoint selection on 411.image-recognition under spike load",
  "benchmarks": [
    "411.image-recognition"
  ],
  "algorithms": [
    "ppo",
    "bayes_opt_online",
    "greedy",
    "default"
  ],
  "environment": {
    "episode_length": 60,
    "load_change_freq": 5,
    "calibration_dir": "results/openwhisk_calibration_x64_stage2_prime",
    "action_space": {
      "memory_options": [128, 256, 512, 1024, 2048, 3008],
      "architecture_options": ["x64"],
      "timeout_options": [60, 120, 300, 900]
    },
    "switch_penalty": 0.02,
    "adaptation_penalty": 0.01,
    "normalize_reward": true,
    "reward_weights": {
      "latency": 0.7,
      "cost": 0.3
    },
    "success_bonus": 0.7,
    "cost_normalization": "log",
    "load_patterns": [
      "spike"
    ]
  },
  "training": {
    "total_timesteps": 12000,
    "ppo_kwargs": {
      "learning_rate": 0.00015,
      "n_steps": 1024,
      "batch_size": 128,
      "n_epochs": 8,
      "gamma": 0.995,
      "gae_lambda": 0.97,
      "clip_range": 0.2,
      "ent_coef": 0.005,
      "vf_coef": 0.6,
      "max_grad_norm": 0.5,
      "verbose": 0
    },
    "imitation_warmstart": {
      "enabled": true,
      "mode": "fixed_config",
      "expert_config": {
        "memory_mb": 3008,
        "architecture": "x64",
        "timeout_sec": 300
      },
      "n_episodes": 8,
      "epochs": 6,
      "batch_size": 256
    },
    "checkpoint_selection": {
      "enabled": true,
      "eval_freq_steps": 2048,
      "n_episodes": 3,
      "metric": "mean_reward"
    }
  },
  "evaluation": {
    "n_episodes": 5
  },
  "baseline": {
    "reoptimize_freq": 10,
    "default_memory": 512
  },
  "reproducibility": {
    "seeds": [
      62
    ]
  }
}
