{
  "description": "PPO tuning on uploader + image-recognition",
  "benchmarks": [
    "120.uploader",
    "411.image-recognition"
  ],
  "algorithms": [
    "ppo",
    "bayes_opt_online",
    "greedy"
  ],
  "environment": {
    "episode_length": 60,
    "load_change_freq": 5,
    "calibration_dir": "results/openwhisk_calibration_x64_stage2_prime",
    "action_space": {
      "preset": "calibrated_x64_8"
    },
    "switch_penalty": 0.02,
    "adaptation_penalty": 0.01,
    "normalize_reward": true,
    "reward_weights": {
      "latency": 0.5,
      "cost": 0.5
    },
    "success_bonus": 0.4,
    "cost_normalization": "sqrt",
    "load_patterns": ["sine", "spike", "decay"]
  },
  "training": {
    "total_timesteps": 90000,
    "ppo_kwargs": {
      "learning_rate": 0.00015,
      "n_steps": 2048,
      "batch_size": 256,
      "n_epochs": 12,
      "gamma": 0.995,
      "gae_lambda": 0.97,
      "clip_range": 0.2,
      "ent_coef": 0.005,
      "vf_coef": 0.6,
      "max_grad_norm": 0.5,
      "verbose": 0
    }
  },
  "evaluation": {
    "n_episodes": 7
  },
  "baseline": {
    "reoptimize_freq": 10,
    "default_memory": 512
  },
  "reproducibility": {
    "seeds": [42]
  }
}
